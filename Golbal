<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Muro Global Eterno</title>
    <!-- Importamos la base de datos descentralizada -->
    <script src="https://cdn.jsdelivr.net/npm/gun/gun.js"></script>
    <style>
        * { box-sizing: border-box; }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background-color: #121212; 
            color: white; 
            display: flex; 
            flex-direction: column; 
            height: 100vh; 
            margin: 0; 
        }
        header { background: #1f1f1f; padding: 15px; text-align: center; border-bottom: 2px solid #333; }
        #muro { 
            flex: 1; 
            overflow-y: auto; 
            padding: 20px; 
            display: flex; 
            flex-direction: column; 
            gap: 10px; 
        }
        .mensaje { 
            background: #2a2a2a; 
            padding: 12px; 
            border-radius: 8px; 
            border-left: 4px solid #00ff88;
            word-wrap: break-word;
            animation: aparecer 0.3s ease-out;
        }
        @keyframes aparecer { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .controles { 
            background: #1f1f1f; 
            padding: 20px; 
            display: flex; 
            gap: 10px; 
            border-top: 2px solid #333;
        }
        input { 
            flex: 1; 
            padding: 12px; 
            border-radius: 5px; 
            border: none; 
            background: #333; 
            color: white; 
            outline: none;
        }
        button { 
            padding: 12px 25px; 
            border-radius: 5px; 
            border: none; 
            background: #00ff88; 
            color: #121212; 
            font-weight: bold; 
            cursor: pointer; 
        }
        button:hover { background: #00cc6e; }
    </style>
</head>
<body>

<header>
    <h1>🌍 Muro Global</h1>
    <p style="font-size: 0.8em; color: #888;">Cualquiera puede escribir. Nada se borra.</p>
</header>

<div id="muro"></div>

<div class="controles">
    <input type="text" id="texto" placeholder="Escribe un mensaje para el mundo..." maxlength="500">
    <button id="enviar">Enviar</button>
</div>

<script>
    // Conexión a nodos públicos de Gun para que los datos viajen por el mundo
    const gun = Gun([
        'https://gun-manhattan.herokuapp.com/gun',
        'https://p2p.era.eco/gun'
    ]);
    
    // "muro_eterno_v1" es la llave de tu base de datos. 
    // Si la cambias, crearás un muro nuevo.
    const baseDeDatos = gun.get('muro_eterno_v1');

    const muroDiv = document.getElementById('muro');
    const input = document.getElementById('texto');
    const boton = document.getElementById('enviar');

    // Función para mandar mensajes
    function enviarMensaje() {
        const msg = input.value;
        if (msg.trim().length > 0) {
            baseDeDatos.set({
                cuerpo: msg,
                fecha: new Date().toISOString()
            });
            input.value = '';
        }
    }

    // Escuchar el botón y la tecla Enter
    boton.onclick = enviarMensaje;
    input.onkeypress = (e) => { if(e.key === 'Enter') enviarMensaje() };

    // Mostrar mensajes en tiempo real (y los viejos también)
    baseDeDatos.map().once((data, id) => {
        if (data && data.cuerpo) {
            const div = document.createElement('div');
            div.className = 'mensaje';
            div.innerText = data.cuerpo;
            muroDiv.appendChild(div);
            // Auto-scroll al final
            muroDiv.scrollTop = muroDiv.scrollHeight;
        }
    });
</script>

</body>
</html>
